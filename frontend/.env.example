# Copy to .env.local for local development (never commit real secrets).
# On Netlify: Site settings → Environment variables (build-time only).

# Public API gateway URL (no trailing slash). Required for production builds.
# Example: https://api-gateway-production.up.railway.app
VITE_GATEWAY_TARGET=http://127.0.0.1:4000

# Optional legacy alias (prefer VITE_GATEWAY_TARGET)
# VITE_API_BASE_URL=http://127.0.0.1:4000
