NODE_ENV=development

# --- DATABASE (LOCAL ONLY) ---
MYSQL_URL=mysql://root:password@127.0.0.1:3306/digital-library

# --- JWT ---
ACCESS_SECRET=your-strong-access-secret-32chars
REFRESH_SECRET=your-strong-refresh-secret-32chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- AUTH SERVICE PORTS ---
PORT=5001
AUTH_GRPC_PORT=5010

# --- LOGS ---
LOG_FORMAT=pretty

# --- OPTIONAL (DISABLE FOR NOW) ---
CONSUL_ENABLED=false