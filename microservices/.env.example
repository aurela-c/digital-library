# =============================================================================
# Digital Library — shared backend environment template
# Copy sections into each Railway service or use a local .env per service.
# Never commit real .env files.
# =============================================================================

NODE_ENV=production

# --- MySQL (all services: auth, user, book, borrow) ---
MYSQL_URL=mysql://root:password@127.0.0.1:3306/digital_library

# --- JWT (use long random strings; same values on auth-service + api-gateway) ---
ACCESS_SECRET=change-me-access-secret-min-32-chars
REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Redis (api-gateway) ---
REDIS_URL=redis://default:password@host:6379

# --- RabbitMQ (user-service, book-service, borrow-service) ---
RABBITMQ_URL=amqp://user:password@host:5672

# --- API Gateway (public HTTP entry — point frontend VITE_GATEWAY_TARGET here) ---
PORT=4000
CORS_ORIGIN=https://your-app.netlify.app
CONSUL_ENABLED=false
AUTH_SERVICE_URL=https://auth-service-xxx.up.railway.app
AUTH_SERVICE_GRPC=auth-service.railway.internal:5010
USER_SERVICE_GRPC=user-service.railway.internal:5012
BOOK_SERVICE_GRPC=book-service.railway.internal:5013
BORROW_SERVICE_GRPC=borrow-service.railway.internal:5014

# --- Per-service HTTP (Railway sets PORT automatically; do not hardcode in code) ---
# auth-service: PORT (HTTP), AUTH_GRPC_PORT=5010
# user-service: PORT (HTTP), USER_GRPC_PORT=5012
# book-service: PORT (HTTP), BOOK_GRPC_PORT=5013
# borrow-service: PORT (HTTP), BORROW_GRPC_PORT=5014

# --- Auth service email (optional) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# AUTH_SKIP_EMAIL_VERIFY=true
